{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh api repos/*/pulls/*:*)",
      "Bash(gh api repos/*/issues/*:*)",
      "Bash(cat ~/.claude/projects/*/*/tool-results/*.txt:*)",
      "Bash(codex exec:*)",
      "Bash(gemini:*)",
      "Bash(env -u CLAUDECODE claude -p:*)",
      "mcp__plan-tools__list_recent_plans",
      "mcp__plan-tools__find_plan_by_title",
      "mcp__plan-tools__read_plan",
      "mcp__plan-tools__write_plan"
    ],
    "deny": [
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git rebase:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|Task",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/smart-lint.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pushover-notify.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pushover-notify.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true
  }
}
