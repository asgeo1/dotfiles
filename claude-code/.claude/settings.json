{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(cd:*)",
      "Bash(git diff:*)",
      "Bash(git status:*)",
      "Bash(git branch:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api repos/*/pulls/*:*)",
      "Bash(gh api repos/*/issues/*:*)",
      "Bash(cat ~/.claude/projects/*/*/tool-results/*.txt:*)",
      "Bash(codex exec:*)",
      "Bash(gemini:*)",
      "Bash(env -u CLAUDECODE claude -p:*)",
      "mcp__plan-tools__list_recent_plans",
      "mcp__plan-tools__find_plan_by_title",
      "mcp__plan-tools__read_plan",
      "mcp__plan-tools__write_plan",
      "mcp__git-tools__git_diff",
      "mcp__git-tools__git_log",
      "mcp__git-tools__git_commit",
      "mcp__review-tools__create_review_session",
      "mcp__review-tools__write_findings",
      "mcp__review-tools__read_all_findings"
    ],
    "deny": [
      "Bash(git stash:*)",
      "Bash(git checkout:*)",
      "Bash(git reset:*)",
      "Bash(git clean:*)",
      "Bash(git push --force:*)",
      "Bash(git rebase:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [
        {"type": "command", "command": "bash ~/.claude/hooks/no-cd-chaining.sh"},
        {"type": "command", "command": "bash ~/.claude/hooks/no-backslash-operators.sh"},
        {"type": "command", "command": "bash ~/.claude/hooks/no-docker-port-prefix.sh"},
        {"type": "command", "command": "bash ~/.claude/hooks/no-remote-path-flags.sh"}
      ]
    }],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/smart-lint.sh --format-only"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/smart-lint.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/pushover-notify.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/smart-lint.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pushover-notify.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true
  },
  "effortLevel": "high",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
